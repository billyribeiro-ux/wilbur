# Root-level ignores. Each app (react-app/, svelte-app/) and the backend
# (wilbur-api/) manages its own ignores; this file covers only shared/root concerns.

# Dependencies (defensive — apps ignore their own as well)
node_modules/

# Rust backend
wilbur-api/target/
wilbur-api/.sqlx/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Debug logs
*-debug.log*
pnpm-debug.log*

# Legacy/archived code
legacy/
.vercel

# Playwright MCP session artifacts
.playwright-mcp/
