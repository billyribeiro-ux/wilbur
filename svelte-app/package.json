{
  "name": "wilbur-trading-room",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "24.14.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:pe7": "node scripts/check-svelte-pe7.mjs",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pocketbase:start": "pocketbase serve --http=127.0.0.1:8090",
    "pocketbase:download": "curl -L https://github.com/pocketbase/pocketbase/releases/download/v0.26.5/pocketbase_0.26.5_linux_amd64.zip -o pocketbase.zip && unzip pocketbase.zip pocketbase && rm pocketbase.zip",
    "db:migrate": "pnpm tsx scripts/migrate-to-pocketbase.ts",
    "db:seed": "pnpm tsx scripts/seed-database.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@libsql/client": "^0.17.3",
    "@livekit/components-core": "^0.12.13",
    "@skeletonlabs/skeleton": "^4.15.2",
    "@skeletonlabs/skeleton-svelte": "^4.15.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "date-fns": "^4.4.0",
    "dompurify": "3.4.9",
    "livekit-client": "^2.19.2",
    "phosphor-svelte": "^3.1.0",
    "pocketbase": "^0.27.0",
    "svelte-sonner": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/mcp": "^0.1.24",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.3",
    "autoprefixer": "^10.5.0",
    "eslint": "10.4.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
