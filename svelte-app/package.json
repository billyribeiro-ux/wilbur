{
  "name": "wilbur-trading-room",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:host": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pocketbase:start": "pocketbase serve --http=127.0.0.1:8090",
    "pocketbase:download": "curl -L https://github.com/pocketbase/pocketbase/releases/download/v0.26.5/pocketbase_0.26.5_linux_amd64.zip -o pocketbase.zip && unzip pocketbase.zip pocketbase && rm pocketbase.zip",
    "db:migrate": "pnpm tsx scripts/migrate-to-pocketbase.ts",
    "db:seed": "pnpm tsx scripts/seed-database.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@libsql/client": "^0.17.2",
    "@livekit/components-core": "^0.12.13",
    "@skeletonlabs/skeleton": "^4.15.1",
    "@skeletonlabs/skeleton-svelte": "^4.15.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "livekit-client": "^2.18.1",
    "phosphor-svelte": "^3.1.0",
    "pocketbase": "^0.26.8",
    "svelte-sonner": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/mcp": "^0.1.22",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
