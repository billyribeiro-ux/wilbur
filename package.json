{
  "name": "wilbur-workspace",
  "version": "2.0.0",
  "private": true,
  "description": "Wilbur Trading Room - Svelte-based application workspace",
  "scripts": {
    "dev": "pnpm --filter wilbur-trading-room dev",
    "dev:host": "pnpm --filter wilbur-trading-room dev:host",
    "build": "pnpm --filter wilbur-trading-room build",
    "preview": "pnpm --filter wilbur-trading-room preview",
    "lint": "pnpm --filter wilbur-trading-room lint",
    "lint:fix": "pnpm --filter wilbur-trading-room lint:fix",
    "format": "pnpm --filter wilbur-trading-room format",
    "test": "pnpm --filter wilbur-trading-room test",
    "test:unit": "pnpm --filter wilbur-trading-room test:unit",
    "test:e2e": "pnpm --filter wilbur-trading-room test:e2e",
    "pocketbase:start": "pnpm --filter wilbur-trading-room pocketbase:start",
    "db:migrate": "pnpm --filter wilbur-trading-room db:migrate",
    "db:seed": "pnpm --filter wilbur-trading-room db:seed"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
