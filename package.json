{
  "name": "revolution-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "dev:network": "vite --host",
    "dev:port": "vite --port",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests scripts --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint src tests scripts --ext .ts,.tsx,.js,.mjs --fix",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:production": "vitest --run --config vitest.config.production.ts",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load-test.js",
    "test:security": "pnpm audit && snyk test",
    "test:all": "pnpm run test:unit && pnpm run test:e2e && pnpm run test:security",
    "validate:production": "tsx scripts/production-validation.ts",
    "preflight": "bash scripts/pre-flight-check.sh",
    "validate:db": "tsx scripts/validate-database-queries.ts",
    "validate:db:watch": "tsx scripts/validate-database-queries.ts --watch",
    "validate:prod": "tsx scripts/validate-production-db.ts",
    "db:schema": "tsx scripts/validate-production-db.ts",
    "validate:live": "tsx scripts/validate-live-queries.ts",
    "validate:full": "pnpm run validate:prod && pnpm run validate:live",
    "investigate:db": "tsx scripts/investigate-database.ts",
    "eradicate:nulls": "tsx scripts/eradicate-nulls.ts",
    "eradicate:nulls:enhanced": "tsx scripts/enhanced-eradicate-nulls.ts",
    "eradicate:nulls:final": "tsx scripts/final-eradicate-nulls.ts",
    "check:nulls": "grep -r '\\bnull\\b' src/ --include='*.ts' --include='*.tsx' | wc -l",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.1",
    "@fluentui/react-icons": "^2.0.320",
    "@phosphor-icons/react": "^2.1.10",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.4",
    "framer-motion": "^12.4.0",
    "immer": "^10.1.1",
    "livekit-client": "^2.17.2",
    "lodash": "^4.17.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "web-vitals": "^4.2.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/css": "^0.14.0",
    "@eslint/js": "^9.19.0",
    "@eslint/json": "^0.10.0",
    "@eslint/markdown": "^6.3.0",
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
