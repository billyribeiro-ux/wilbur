{
  "name": "revolution-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "24.14.1",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:react": "vite",
    "dev:svelte": "pnpm --dir svelte-app run dev",
    "dev:host": "vite --host",
    "dev:network": "vite --host",
    "dev:port": "vite --port",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src tests scripts --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint src tests scripts --ext .ts,.tsx,.js,.mjs --fix",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:coverage": "vitest --coverage",
    "test:production": "vitest --run --config vitest.config.production.ts",
    "test:e2e": "playwright test",
    "test:load": "k6 run tests/load-test.js",
    "test:security": "pnpm audit && snyk test",
    "test:all": "pnpm run test:unit && pnpm run test:e2e && pnpm run test:security",
    "validate:production": "tsx scripts/production-validation.ts",
    "preflight": "bash scripts/pre-flight-check.sh",
    "validate:db": "tsx scripts/validate-database-queries.ts",
    "validate:db:watch": "tsx scripts/validate-database-queries.ts --watch",
    "validate:prod": "tsx scripts/validate-production-db.ts",
    "db:schema": "tsx scripts/validate-production-db.ts",
    "validate:live": "tsx scripts/validate-live-queries.ts",
    "validate:full": "pnpm run validate:prod && pnpm run validate:live",
    "investigate:db": "tsx scripts/investigate-database.ts",
    "eradicate:nulls": "tsx scripts/eradicate-nulls.ts",
    "eradicate:nulls:enhanced": "tsx scripts/enhanced-eradicate-nulls.ts",
    "eradicate:nulls:final": "tsx scripts/final-eradicate-nulls.ts",
    "check:nulls": "grep -r '\\bnull\\b' src/ --include='*.ts' --include='*.tsx' | wc -l",
    "check:isolation": "node scripts/check-app-isolation.mjs",
    "check:pe7": "node scripts/check-react-pe7.mjs",
    "check:pe7:svelte": "node scripts/check-svelte-pe7.mjs",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.7",
    "@fluentui/react-icons": "^2.0.323",
    "@phosphor-icons/react": "^2.1.10",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "immer": "^11.1.4",
    "lodash": "^4.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": ">=10.0.0"
      }
    }
  }
}
